---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';

const groups = [
  {
    heading: '시작하기 전에',
    items: [
      {
        q: '한 곳만 가입하면 충분한가요?',
        a: '네. 한 서버의 한 계정으로 다른 서버, 다른 서비스(Pixelfed, PeerTube 등)의 사람을 팔로우하고 답장할 수 있어요. 여러 개 만들 필요는 없습니다.',
      },
      {
        q: '어느 서버를 고르는 게 좋을까요?',
        a: '가장 간단한 기준은 "관심사가 겹치는가"입니다. 개발자라면 hackers.pub, 일러스트라면 oeee.cafe, 특정 취향이 없다면 planet.moe 같이 종합 서버도 있어요. 마음에 안 들면 나중에 옮기는 것도 쉽습니다.',
      },
      {
        q: '사용자가 얼마나 있나요?',
        a: 'fedidb 기준 전체 연합우주는 약 12.7M 계정, 월간 활성 946K, 서버 42K입니다. 한국어 커뮤니티만 봐도 주제별로 수백~수천 명 단위가 운영되고 있어요.',
      },
    ],
  },
  {
    heading: '서버와 데이터',
    items: [
      {
        q: '내가 가입한 서버가 문을 닫으면 어떻게 되나요?',
        a: '대부분의 서비스는 계정 이사(migration) 기능이 있어서, 다른 서버로 옮길 때 팔로우 관계가 따라옵니다. 글과 미디어는 내 계정으로 내보내기가 가능하니, 서버 운영자가 중단을 예고하면 미리 옮기거나 백업할 수 있어요.',
      },
      {
        q: '이사하면 예전 글도 따라가나요?',
        a: '팔로우 관계는 자동으로 따라갑니다. 과거 게시물 자체는 기술적으로 이전되지 않지만, 내보내기(Export) → 새 서버로 가져오기(Import)를 지원하는 서비스가 늘고 있어요.',
      },
      {
        q: '내 데이터는 누가 보관하나요?',
        a: '가입한 서버 운영자가 보관합니다. 서버 정책을 읽어보고 운영자가 신뢰할 만한지 확인하는 게 중요해요. 의심스럽다면 GDPR·개인정보처리방침이 명시된 서버를 고르세요.',
      },
    ],
  },
  {
    heading: '모더레이션과 운영',
    items: [
      {
        q: '모더레이션은 어떻게 되나요?',
        a: '서버마다 운영자와 운영 정책이 다릅니다. 각 서버의 규칙 페이지에 명시되고, 신고·차단 기능이 기본 제공돼요. 문제가 되는 다른 서버 전체를 차단하는 기능(서버 차단)도 있습니다.',
      },
      {
        q: '누가 서버 비용을 내나요?',
        a: '대부분 운영자의 자비 또는 사용자 후원(Patreon, OpenCollective 등)으로 유지됩니다. 광고 수익 모델이 없기 때문에, 서버가 오래 유지되려면 커뮤니티의 자발적 기여가 중요해요.',
      },
      {
        q: '혐오·괴롭힘에 어떻게 대응하나요?',
        a: '개별 신고·차단 외에도, 서버 차원에서 특정 서버 전체를 차단(defederate)할 수 있어요. 한국어 커뮤니티 대부분은 혐오표현에 엄격한 편이고, 신고하면 운영자가 빠르게 대응하는 문화가 있습니다.',
      },
    ],
  },
  {
    heading: '기술',
    items: [
      {
        q: 'ActivityPub가 뭔가요?',
        a: '서로 다른 서버와 앱이 같은 방식으로 대화할 수 있게 해주는 오픈 프로토콜입니다. W3C 표준이며, Mastodon·Pixelfed·PeerTube 같은 서비스들이 이 위에서 작동해요. 이메일이 서로 다른 회사 간에도 주고받아지는 것과 비슷한 원리입니다.',
      },
      {
        q: 'Bluesky나 Nostr와는 다른가요?',
        a: '다른 프로토콜이에요. 연합우주는 ActivityPub, Bluesky는 AT Protocol, Nostr는 자체 프로토콜을 씁니다. 일부 브릿지로 상호연동 실험이 진행 중이긴 하지만, 기본적으로는 서로 다른 네트워크라고 생각하면 됩니다.',
      },
      {
        q: 'nodeinfo는 뭐고, 사용자 수는 어디서 가져오나요?',
        a: 'nodeinfo는 연합우주 서버가 자신의 소프트웨어·사용자 수 같은 메타데이터를 공개하는 표준 엔드포인트예요 (`/.well-known/nodeinfo`). 이 사이트의 디렉토리는 이 nodeinfo를 직접 조회해서 사용자 수를 가져옵니다.',
      },
    ],
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: groups.flatMap((g) =>
    g.items.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a,
      },
    }))
  ),
};
---

<Layout
  title="자주 묻는 질문 — 연합우주(페디버스/Fediverse/ActivityPub)"
  description="연합우주(페디버스·Fediverse·ActivityPub) 시작과 운영에 대한 자주 묻는 질문. 서버 선택, 계정 이사, 모더레이션, 프로토콜 설명."
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />
  <Nav />

  <section class="page-hero">
    <div class="wrap">
      <span class="sec-eyebrow">자주 묻는 질문</span>
      <h1 class="page-title">
        궁금한 <span class="hl">것들</span>.
      </h1>
      <p class="page-lead">
        시작 전 자주 받는 질문을 시작하기·서버·모더레이션·기술 네 카테고리로 정리했어요. 빠진 질문이
        있다면 <a href="/contribute" class="ilink">GitHub 이슈</a>로 알려주세요.
      </p>
    </div>
  </section>

  {
    groups.map((g) => (
      <section class="faq-group">
        <FAQ items={g.items} title={g.heading} eyebrow="FAQ" />
      </section>
    ))
  }

  <FinalCTA
    title="답변을 보셨다면 이제 실제로."
    body="연합우주는 설명보다 직접 해보는 게 훨씬 빠른 공간이에요. 관심 가는 커뮤니티부터 가볍게 시작해보세요."
    primary={{ href: '/communities', label: '커뮤니티 보러 가기' }}
    secondary={{ href: '/contribute', label: '커뮤니티 기여하기' }}
  />
  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 96px 0 48px;
  }
  .page-title {
    font-size: clamp(40px, 5.6vw, 72px);
    line-height: 1.35;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0 0 20px;
    color: var(--ink);
  }
  .page-title .hl {
    display: inline-block;
    padding: 0 6px;
    background: var(--mint);
    border-radius: 8px;
    transform: rotate(-1deg);
  }
  .page-lead {
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-2);
    max-width: 62ch;
  }
  .ilink {
    color: var(--mint-deep);
    border-bottom: 1px solid color-mix(in oklab, var(--mint-deep) 30%, transparent);
  }
  .ilink:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }
  .faq-group :global(section#faq) {
    padding: 12px 0 20px;
  }
  .faq-group :global(.faq-head) {
    margin-bottom: 18px;
    text-align: left;
  }
  .faq-group :global(.faq-head .sec-eyebrow) {
    display: none;
  }
  .faq-group :global(.faq-head .sec-h) {
    font-size: clamp(20px, 2.4vw, 26px);
    margin: 0;
    text-align: left;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }
  .faq-group :global(.faqs) {
    max-width: none;
  }

  @media (max-width: 1024px) {
    .page-hero {
      padding: 72px 0 32px;
    }
  }
  @media (max-width: 720px) {
    .page-hero {
      padding: 56px 0 24px;
    }
  }
</style>
