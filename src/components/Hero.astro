---
import NetworkBg from './NetworkBg.astro';
---

<section class="hero">
  <NetworkBg />
  <div class="hero-ring"></div>
  <div class="hero-ring-2"></div>
  <div class="hero-badge">연합우주 — Fediverse</div>
  <h1 class="hero-title">
    <span class="hero-title-line1">소셜 미디어의</span>
    <span class="hero-title-gradient">다른 가능성</span>
  </h1>
  <p class="hero-sub">
    플랫폼의 벽을 넘어, 취향으로 연결되는<br />
    새로운 소셜 네트워크가 있습니다
  </p>
  <div class="hero-actions">
    <a href="#instances" class="btn-glow">내 공간 찾기 →</a>
    <a href="#niches" class="btn-ghost">더 알아보기</a>
  </div>
  <div class="scroll-hint">
    <span>SCROLL</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 6rem;
    position: relative;
    overflow: hidden;
  }


  .hero-ring {
    position: absolute;
    width: 500px;
    height: 500px;
    border: 1px solid rgba(99, 102, 241, 0.08);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .hero-ring-2 {
    position: absolute;
    width: 700px;
    height: 700px;
    border: 1px solid rgba(167, 139, 250, 0.05);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .hero-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--violet);
    margin-bottom: 2rem;
    padding: 0.4rem 1.2rem;
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 20px;
    background: rgba(167, 139, 250, 0.05);
    animation: fadeUp 0.8s ease forwards 0.2s;
    opacity: 0;
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 0.4em;
    animation: fadeUp 0.8s ease forwards 0.4s;
    opacity: 0;
  }

  .hero-title-line1 {
    display: block;
    margin-bottom: 0.05em;
  }

  .hero-title-gradient {
    background: linear-gradient(135deg, var(--violet), var(--pink), var(--indigo));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 200%;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.9;
    max-width: 440px;
    margin: 0 auto 2.5rem;
    font-weight: 300;
    animation: fadeUp 0.8s ease forwards 0.6s;
    opacity: 0;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    animation: fadeUp 0.8s ease forwards 0.8s;
    opacity: 0;
  }

  .hero-actions a {
    text-decoration: none;
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .scroll-hint span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.15em;
  }

  .scroll-line {
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, var(--violet), transparent);
  }

  @media (max-width: 768px) {
    .hero { padding: 7rem 1.5rem 4rem; }
    .hero-ring { width: 350px; height: 350px; }
    .hero-ring-2 { width: 500px; height: 500px; }
    .hero-sub { font-size: 1rem; margin-bottom: 2rem; }
  }

  @media (max-width: 480px) {
    .hero { padding: 6rem 1.2rem 3.5rem; min-height: 90vh; }
    .hero-badge { font-size: 0.6rem; padding: 0.35rem 1rem; margin-bottom: 1.5rem; }
    .hero-ring { width: 280px; height: 280px; }
    .hero-ring-2 { width: 400px; height: 400px; }
    .hero-sub { font-size: 0.92rem; line-height: 1.8; }
    .hero-actions { flex-direction: column; align-items: center; gap: 0.6rem; }
    .hero-actions :global(.btn-glow),
    .hero-actions :global(.btn-ghost) {
      width: 100%;
      max-width: 260px;
      text-align: center;
      font-size: 0.8rem;
    }
  }
</style>
