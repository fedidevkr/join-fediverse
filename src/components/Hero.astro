---
const apps = [
  { name: 'Mastodon', logo: '/images/logos/fediverse/mastodon.svg' },
  { name: 'Pixelfed', logo: '/images/logos/fediverse/pixelfed.svg' },
  { name: 'PeerTube', logo: '/images/logos/fediverse/peertube.svg' },
  { name: 'Lemmy', logo: '/images/logos/fediverse/lemmy.svg' },
  { name: 'WriteFreely', logo: '/images/logos/fediverse/writefreely.svg' },
  { name: 'Hackers Pub', logo: '/images/logos/fediverse/hackerspub.svg' },
  { name: 'Misskey', logo: '/images/logos/fediverse/misskey.svg' },
];
---

<header class="hero" id="top">
  <div class="wrap">
    <div class="hero-left">
      <div class="hero-eyebrow">
        joinfediverse.kr
        <span class="pulse" aria-hidden="true"></span>
        라이브 피드
      </div>
      <h1>
        이야기가<br />
        흐르는<br />
        <span class="hl">소셜 네트워크</span>가<br />
        이미 있어요.
      </h1>
      <p class="lead">
        연합우주는 작은 공동체들이 공통 프로토콜로 이어진 소셜 네트워크예요. 광고 대신 팔로우가 먼저
        오고, 한 회사가 전체를 소유하지 않아요. 마음이 맞는 사람들이 모이는 작은 공간을 골라 시작해보세요.
      </p>
      <div class="cta-row">
        <a href="#communities" class="btn btn-primary">
          커뮤니티 보러가기 <span class="arr">→</span>
        </a>
        <a href="#how" class="btn btn-ghost">어떻게 작동하나요?</a>
      </div>
      <div class="hero-meta">
        <div class="stat"><b>12.7M</b><span>총 사용자</span></div>
        <div class="vbar"></div>
        <div class="stat"><b>946K</b><span>월간 활성</span></div>
        <div class="vbar"></div>
        <div class="stat"><b>42K</b><span>활성 서버</span></div>
      </div>
      <p class="hero-source">
        통계 출처 ·
        <a href="https://fedidb.com" target="_blank" rel="noopener">fedidb.com</a>
      </p>
    </div>

    <div class="hero-vis" aria-hidden="true">
      <div class="grid-bg"></div>
      <div class="blob b1"></div>
      <div class="blob b2"></div>

      <svg class="wires" viewBox="0 0 520 540" preserveAspectRatio="none">
        <path d="M 150 80 Q 260 200 380 140"></path>
        <path d="M 380 140 Q 300 320 200 400"></path>
        <path d="M 150 80 Q 140 280 200 400"></path>
      </svg>

      <div class="floating-badge fb-top"><span class="dot"></span>새 글 · 3분 전</div>
      <div class="floating-badge fb-mid"><span class="dot"></span>다른 서버에서 답장</div>
      <div class="floating-badge fb-bot"><span class="dot"></span>#관심사 해시태그</div>

      <article class="card cA">
        <div class="c-head">
          <div class="av">민</div>
          <div class="meta">
            <span class="name">민지</span>
            <span class="hand">@minji@hackers.pub</span>
          </div>
        </div>
        <div class="c-body">
          오늘 리팩터링한 코드, 한 줄로 줄었는데 테스트가 두 배 늘었다. <span class="tag">#devlog</span>
        </div>
        <div class="c-foot"><span>♡ 24</span><span>↻ 7</span><span>💬 5</span></div>
      </article>

      <article class="card cB">
        <div class="c-head">
          <div class="av">준</div>
          <div class="meta">
            <span class="name">준호</span>
            <span class="hand">@jun@oeee.cafe</span>
          </div>
        </div>
        <div class="c-body">
          새벽 낙서. 밝을 때 다시 보면 또 다르겠지. <span class="tag">#일러스트</span>
        </div>
        <div class="c-foot"><span>♡ 48</span><span>↻ 12</span></div>
      </article>

      <article class="card cC">
        <div class="c-head">
          <div class="av">현</div>
          <div class="meta">
            <span class="name">현수</span>
            <span class="hand">@hyun@kurry.social</span>
          </div>
        </div>
        <div class="c-body">
          <span class="at">@minji</span> 같은 서버 아닌데 알림이 딱 와서 신기 😆
        </div>
        <div class="c-foot"><span>♡ 31</span><span>↻ 3</span><span>💬 9</span></div>
      </article>
    </div>
  </div>
</header>

<div class="strip">
  <div class="wrap">
    <span class="label">연합우주에서 돌아가는 서비스들</span>
    <div class="apps">
      {
        apps.map((a) => (
          <span class="app" title={a.name}>
            <img src={a.logo} alt={a.name} width="30" height="30" loading="lazy" />
            <span class="app-name">{a.name}</span>
          </span>
        ))
      }
    </div>
  </div>
</div>

<style>
  .hero {
    position: relative;
    padding: 96px 0 80px;
    overflow: hidden;
  }
  .hero .wrap {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 6px 14px 6px 8px;
    border-radius: var(--radius-pill);
    background: white;
    border: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-2);
    margin-bottom: 28px;
  }
  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--mint-deep);
    box-shadow: 0 0 0 0 color-mix(in oklab, var(--mint-deep) 60%, transparent);
    animation: pulse 2s infinite;
    display: inline-block;
  }
  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 color-mix(in oklab, var(--mint-deep) 50%, transparent);
    }
    70% {
      box-shadow: 0 0 0 10px color-mix(in oklab, var(--mint-deep) 0%, transparent);
    }
    100% {
      box-shadow: 0 0 0 0 color-mix(in oklab, var(--mint-deep) 0%, transparent);
    }
  }

  .hero h1 {
    font-size: clamp(42px, 6.2vw, 84px);
    line-height: 1.5;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0 0 24px;
    color: var(--ink);
  }
  .hero h1 .hl {
    display: inline-block;
    position: relative;
    padding: 0 6px;
    background: var(--mint);
    border-radius: 8px;
    transform: rotate(-1deg);
  }

  .hero .lead {
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink-2);
    max-width: 50ch;
    margin: 0 0 36px;
  }

  .hero-meta {
    display: flex;
    gap: 28px;
    align-items: center;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }
  .hero-meta .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hero-meta .stat b {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .hero-meta .stat span {
    font-size: 12px;
    color: var(--ink-3);
    font-family: var(--mono);
  }
  .hero-meta .vbar {
    width: 1px;
    height: 32px;
    background: var(--line);
  }
  .hero-source {
    margin: 12px 0 0;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }
  .hero-source a {
    color: var(--mint-deep);
    border-bottom: 1px solid color-mix(in oklab, var(--mint-deep) 30%, transparent);
  }
  .hero-source a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .hero-vis {
    position: relative;
    height: 540px;
    isolation: isolate;
  }
  .hero-vis .grid-bg {
    position: absolute;
    inset: -40px;
    z-index: -1;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 75%);
    opacity: 0.7;
  }
  .hero-vis .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.55;
    z-index: -1;
  }
  .hero-vis .blob.b1 {
    width: 320px;
    height: 320px;
    background: var(--mint);
    top: 20px;
    left: -40px;
  }
  .hero-vis .blob.b2 {
    width: 280px;
    height: 280px;
    background: var(--lilac);
    bottom: 20px;
    right: -20px;
  }

  .hero-vis svg.wires {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
  }
  .hero-vis svg.wires path {
    fill: none;
    stroke: var(--ink);
    stroke-width: 1.5;
    stroke-dasharray: 4 4;
    opacity: 0.25;
  }

  .card {
    position: absolute;
    background: white;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px;
    box-shadow:
      0 2px 4px rgba(15, 21, 18, 0.03),
      0 20px 40px -20px rgba(15, 21, 18, 0.14);
    transition: transform 0.3s ease;
  }
  .card:hover {
    transform: translateY(-4px) rotate(0) !important;
  }
  .card .c-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .card .av {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 14px;
    color: var(--ink);
  }
  .card .meta {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .card .meta .name {
    font-weight: 600;
    font-size: 13.5px;
    color: var(--ink);
  }
  .card .meta .hand {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
  }
  .card .c-body {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-2);
  }
  .card .c-body .tag {
    color: var(--lilac-deep);
    font-weight: 500;
  }
  .card .c-body .at {
    color: var(--mint-deep);
    font-weight: 500;
  }
  .card .c-foot {
    margin-top: 12px;
    display: flex;
    gap: 14px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
  }

  .cA {
    top: 20px;
    left: 30px;
    width: 280px;
    transform: rotate(-3deg);
    z-index: 3;
  }
  .cB {
    top: 90px;
    right: 10px;
    width: 260px;
    transform: rotate(2.5deg);
    z-index: 4;
  }
  .cC {
    bottom: 40px;
    left: 60px;
    width: 300px;
    transform: rotate(1.5deg);
    z-index: 5;
  }
  .cA .av {
    background: var(--mint-soft);
    color: var(--mint-deep);
  }
  .cB .av {
    background: var(--lilac-soft);
    color: var(--lilac-deep);
  }
  .cC .av {
    background: #ffe0d0;
    color: #b54020;
  }

  .floating-badge {
    position: absolute;
    background: white;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    padding: 8px 14px 8px 10px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ink-2);
    box-shadow: 0 10px 24px -12px rgba(15, 21, 18, 0.2);
    z-index: 6;
  }
  .floating-badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--mint-deep);
  }
  .fb-top {
    top: 0;
    right: 80px;
    transform: rotate(3deg);
  }
  .fb-mid {
    top: 230px;
    left: -10px;
    transform: rotate(-4deg);
  }
  .fb-mid .dot {
    background: var(--lilac-deep);
  }
  .fb-bot {
    bottom: 10px;
    right: 30px;
    transform: rotate(2deg);
  }
  .fb-bot .dot {
    background: var(--coral);
  }

  .strip {
    padding: 24px 0 40px;
    border-bottom: 1px solid var(--line);
  }
  .strip .wrap {
    display: flex;
    gap: 40px;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .strip .label {
    font-family: var(--sans);
    font-size: 17px;
    font-weight: 600;
    color: var(--ink-2);
    letter-spacing: -0.005em;
  }
  .strip .apps {
    display: flex;
    gap: 22px 28px;
    flex-wrap: wrap;
    align-items: center;
  }
  .strip .app {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.005em;
    color: var(--ink);
    filter: grayscale(0.2);
    opacity: 0.88;
    transition:
      filter 0.2s,
      opacity 0.2s;
  }
  .strip .app:hover {
    filter: none;
    opacity: 1;
  }
  .strip .app img {
    width: 30px;
    height: 30px;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 1024px) {
    .hero {
      padding: 64px 0 64px;
    }
    .hero .wrap {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero-vis {
      height: 500px;
      max-width: 520px;
      margin: 0 auto;
      width: 100%;
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding: 48px 0 48px;
    }
    .hero-eyebrow {
      font-size: 11px;
    }
    .hero h1 {
      font-size: clamp(36px, 9vw, 52px);
      margin-bottom: 18px;
    }
    .hero .lead {
      font-size: 15.5px;
      margin-bottom: 28px;
    }
    .hero-meta {
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 32px;
      padding-top: 24px;
    }
    .hero-meta .stat b {
      font-size: 19px;
    }
    .hero-meta .vbar {
      display: none;
    }
    .hero-vis {
      height: 440px;
      margin: 0 -12px;
    }
    .cA {
      width: 230px;
      top: 10px;
      left: 10px;
    }
    .cB {
      width: 220px;
      right: 10px;
      top: 70px;
    }
    .cC {
      width: 250px;
      bottom: 20px;
      left: 30px;
    }
    .fb-top {
      right: 30px;
    }
    .fb-bot {
      bottom: 0;
      right: 10px;
    }
    .fb-mid {
      left: 0;
      top: 200px;
    }
    .strip {
      padding: 20px 0 32px;
    }
    .strip .wrap {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .strip .apps {
      gap: 18px;
    }
  }
</style>
