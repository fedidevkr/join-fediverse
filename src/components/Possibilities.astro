              <rect x="310" y="146" width="66" height="24" rx="12" fill="#0F1512"/>
              <text x="343" y="162" text-anchor="middle" font-family="Pretendard,sans-serif" font-size="10" font-weight="500" fill="#F6F6F2">+ 팔로우</text>
            </g>

            <g>
              <rect x="14" y="190" width="372" height="48" rx="12" fill="white" stroke="rgba(15,21,18,0.1)"/>
              <circle cx="36" cy="214" r="13" fill="#FFE0D0"/>
              <text x="36" y="219" text-anchor="middle" font-family="Pretendard,sans-serif" font-size="11" font-weight="700" fill="#B54020">현</text>
              <text x="58" y="211" font-family="Pretendard,sans-serif" font-size="12" font-weight="600" fill="#0F1512">현수</text>
              <text x="58" y="227" font-family="JetBrains Mono,monospace" font-size="9" fill="#5A615D">@hyun@kurry.social</text>
              <rect x="310" y="202" width="66" height="24" rx="12" fill="#0F1512"/>
              <text x="343" y="218" text-anchor="middle" font-family="Pretendard,sans-serif" font-size="10" font-weight="500" fill="#F6F6F2">+ 팔로우</text>
