<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    position: relative;
    margin-top: 48px;
  }
  .step {
    background: white;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 28px 26px 26px;
    display: flex;
    flex-direction: column;
  }
  .snum {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--ink);
    color: var(--bg);
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 18px;
  }
  .step h4 {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 10px;
    letter-spacing: -0.015em;
  }
  .step p {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0 0 18px;
  }
  .mockup {
    margin-top: auto;
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    overflow: hidden;
    background: var(--bg);
    box-shadow: inset 0 0 0 1px rgba(15, 21, 18, 0.02);
  }
  .mockup svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 1024px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 720px) {
    .steps {
      gap: 14px;
    }
    .step {
      padding: 22px 20px;
    }
  }
</style>
