              <circle cx="368" cy="136" r="9" fill="none" stroke="rgba(15,21,18,0.2)" stroke-width="1.4"/>
            </g>

            <g>
              <rect x="14" y="172" width="372" height="56" rx="12" fill="white" stroke="rgba(15,21,18,0.1)"/>
              <circle cx="40" cy="200" r="15" fill="#FFE0D0"/>
              <text x="40" y="205" text-anchor="middle" font-family="Pretendard,sans-serif" font-size="13" font-weight="700" fill="#B54020">K</text>
              <text x="64" y="196" font-family="Pretendard,sans-serif" font-size="13" font-weight="600" fill="#0F1512">kurry.social</text>
