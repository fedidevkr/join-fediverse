            </g>

            <g>
              <rect x="14" y="78" width="372" height="48" rx="12" fill="white" stroke="rgba(15,21,18,0.1)"/>
              <circle cx="36" cy="102" r="13" fill="#CEF2DF"/>
              <text x="36" y="107" text-anchor="middle" font-family="Pretendard,sans-serif" font-size="11" font-weight="700" fill="#0F6B4C">민</text>
              <text x="58" y="99" font-family="Pretendard,sans-serif" font-size="12" font-weight="600" fill="#0F1512">민지</text>
              <text x="58" y="115" font-family="JetBrains Mono,monospace" font-size="9" fill="#5A615D">@minji@hackers.pub</text>
              <rect x="310" y="90" width="66" height="24" rx="12" fill="#CEF2DF"/>
