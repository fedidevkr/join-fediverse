            </g>

            <g>
              <rect x="14" y="134" width="372" height="48" rx="12" fill="white" stroke="rgba(15,21,18,0.1)"/>
              <circle cx="36" cy="158" r="13" fill="#EBE4FA"/>
              <text x="36" y="163" text-anchor="middle" font-family="Pretendard,sans-serif" font-size="11" font-weight="700" fill="#5B3DBF">준</text>
              <text x="58" y="155" font-family="Pretendard,sans-serif" font-size="12" font-weight="600" fill="#0F1512">준호</text>
