              <circle cx="40" cy="136" r="15" fill="#EBE4FA"/>
              <text x="40" y="141" text-anchor="middle" font-family="Pretendard,sans-serif" font-size="13" font-weight="700" fill="#5B3DBF">O</text>
              <text x="64" y="132" font-family="Pretendard,sans-serif" font-size="13" font-weight="600" fill="#0F1512">oeee.cafe</text>
