---
const posts = [
  {
    av: '민',
    avBg: 'var(--mint-soft)',
    name: '민지',
    hand: '@minji@hackers.pub',
    when: '3분 전',
    body: '오늘 리팩터링한 코드 한 줄로 줄었는데 테스트가 두 배 늘었다. 이럴 땐 기분이 좋은 건지 의심스러운 건지.',
    tags: ['#devlog', '#코드리뷰'],
    meta: ['♡ 24', '↻ 7', '💬 5'],
  },
  {
    av: '준',
    avBg: 'var(--lilac-soft)',
    name: '준호',
    hand: '@jun@oeee.cafe',
    when: '12분 전',
    body: '새벽에 그린 낙서. 밝을 때 다시 보면 또 다를 거다. 오늘은 이 정도로.',
    tags: ['#일러스트'],
    meta: ['♡ 48', '↻ 12'],
  },
  {
    av: '현',
    avBg: '#FFE0D0',
    name: '현수',
    hand: '@hyun@kurry.social',
    when: '34분 전',
    at: '@minji@hackers.pub',
    body: ' 다른 서버인데 알림이 바로 와서 신기했어요. 팔로우 눌러도 돼요? 😆',
    meta: ['♡ 31', '↻ 3', '💬 9'],
  },
  {
    av: '서',
    avBg: 'color-mix(in oklab, var(--sun) 45%, white)',
    name: '서윤',
    hand: '@seoyun@mastodon.kr',
    when: '1시간 전',
    body: '읽고 있는 책 인덱스를 ',
    link: 'BookWyrm',
    bodyAfter: '으로 옮기는 중. 서평을 여기 친구들이랑 주고받을 수 있다는 게 뭔가 좋아서.',
    tags: ['#독서'],
    meta: ['♡ 18', '↻ 2'],
  },
  {
    av: '지',
    avBg: 'var(--mint-soft)',
    name: '지훈',
    hand: '@jh@hackers.pub',
    when: '2시간 전',
    body: '오픈소스 PR 머지됐어요. 스크린샷. 개발 블로그는 오래 쉬었는데 여기 올리는 건 부담이 덜하다.',
    meta: ['♡ 62', '↻ 21', '💬 14'],
  },
];
---

<section id="live">
  <div class="wrap">
    <div class="live">
      <div class="decorative-grid"></div>
      <div class="live-grid">
        <div class="live-intro">
          <span class="sec-eyebrow">지금 이 순간</span>
          <h2 class="sec-h">
            피드는<br /><span class="hl">이런 느낌</span>이에요.
          </h2>
          <p class="sec-sub">
            광고나 알고리즘 추천이 아니라, 팔로우한 사람의 글이 시간 순서대로 흐릅니다. 서로 다른
            서버에 있어도 한 계정으로 답장하고 팔로우할 수 있어요.
          </p>

          <div class="live-explain">
            <ul>
              <li>
                <span class="ic">01</span>
                <div>
                  <b>시간 순서대로</b>
                  <p>알고리즘이 섞어 보여주지 않아요. 팔로우 = 타임라인.</p>
                </div>
              </li>
              <li>
                <span class="ic lilac">02</span>
                <div>
                  <b>다른 서버도 그대로 보여요</b>
                  <p>같은 프로토콜 위에 있어서 답장·팔로우가 서버 경계를 넘어요.</p>
                </div>
              </li>
              <li>
                <span class="ic sun">03</span>
                <div>
                  <b>광고 없어요</b>
                  <p>대부분의 서버는 후원으로 운영돼요. 피드는 내 취향 그대로.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <div class="feed-scroll">
          {
            posts.map((p) => (
              <article class="post">
                <div class="p-head">
                  <div class="av" style={`background:${p.avBg}`}>
                    {p.av}
                  </div>
                  <span class="name">{p.name}</span>
                  <span class="hand">{p.hand}</span>
                  <span class="when">{p.when}</span>
                </div>
                <div class="p-body">
                  {p.at && <span class="at">{p.at}</span>}
                  {p.body}
                  {p.link && <span class="link">{p.link}</span>}
                  {p.bodyAfter}
                  {p.tags?.length ? ' ' : null}
                  {p.tags?.map((t) => (
                    <>
                      <span class="tag">{t}</span>{' '}
                    </>
                  ))}
                </div>
                <div class="p-meta">
                  {p.meta.map((m) => (
                    <span>{m}</span>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .live {
    background: var(--ink);
    color: var(--bg);
    border-radius: 28px;
    padding: 56px 48px 48px;
    margin: 0;
    position: relative;
    overflow: hidden;
  }
  .live :global(.sec-eyebrow) {
    background: rgba(126, 227, 184, 0.18);
    color: var(--mint);
  }
  .live :global(.sec-h) {
    color: white;
  }
  .live :global(.sec-h .hl) {
    background: var(--mint);
    color: var(--ink);
  }
  .live :global(.sec-sub) {
    color: color-mix(in oklab, var(--bg) 70%, var(--ink));
  }

  .decorative-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at 80% 0, black, transparent 70%);
    pointer-events: none;
  }

  .live-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    position: relative;
  }

  .feed-scroll {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-height: 520px;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(to bottom, black 88%, transparent 100%);
  }
  .post {
    background: #181f1c;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 16px 18px;
  }
  .p-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .p-head .av {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 13px;
    font-weight: 700;
    color: var(--ink);
  }
  .p-head .name {
    font-weight: 600;
    font-size: 14px;
  }
  .p-head .hand {
    font-family: var(--mono);
    font-size: 11px;
    color: #7f8782;
    margin-left: 4px;
  }
  .p-head .when {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 11px;
    color: #7f8782;
  }
  .p-body {
    font-size: 14px;
    line-height: 1.6;
    color: #d7dbd8;
  }
  .p-body .tag {
    color: var(--mint);
  }
  .p-body .at {
    color: var(--lilac);
  }
  .p-body .link {
    color: var(--mint);
  }
  .p-meta {
    display: flex;
    gap: 18px;
    margin-top: 12px;
    font-family: var(--mono);
    font-size: 11px;
    color: #7f8782;
  }

  .live-explain ul {
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .live-explain li {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 16px;
    align-items: start;
  }
  .live-explain li .ic {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(126, 227, 184, 0.15);
    color: var(--mint);
    display: grid;
    place-items: center;
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 500;
  }
  .live-explain li .ic.lilac {
    background: rgba(201, 184, 245, 0.18);
    color: var(--lilac);
  }
  .live-explain li .ic.sun {
    background: rgba(255, 209, 102, 0.15);
    color: var(--sun);
  }
  .live-explain li b {
    display: block;
    font-size: 14.5px;
    color: white;
    margin-bottom: 4px;
  }
  .live-explain li p {
    margin: 0;
    font-size: 13.5px;
    color: #a8aeaa;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .live {
      padding: 48px 36px 40px;
    }
    .live-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  @media (max-width: 720px) {
    .live {
      padding: 40px 24px 32px;
      border-radius: 20px;
    }
    .live-explain li {
      grid-template-columns: 32px 1fr;
      gap: 12px;
    }
  }
</style>
