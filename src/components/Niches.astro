---
const niches = [
  { icon: '🎨', label: '일러스트 · 창작', desc: '상업 플랫폼의 속도보다 작업의 결을 더 중요하게 여기는 사람들. 작품과 제작 과정을 길게 나눌 수 있습니다.', tags: ['팬덤', '디지털아트', '커미션'] },
  { icon: '⌨️', label: '개발 · 테크', desc: '제품 링크보다 생각과 시행착오가 더 많이 오가는 공간. 글과 토론이 비교적 차분하게 축적됩니다.', tags: ['오픈소스', '개발블로그', '해커 문화'] },
  { icon: '🐾', label: '퍼리 · 서브컬처', desc: '외부에선 설명이 길어지는 취향도 여기서는 기본 전제로 통합니다. 작은 공동체의 밀도가 강점입니다.', tags: ['퍼리', '오리지널 캐릭터', '행사 후기'] },
  { icon: '✍️', label: '글쓰기 · 블로깅', desc: '짧은 감상부터 긴 에세이까지. 조회 수보다 읽는 사람의 분위기를 더 중요하게 둘 수 있습니다.', tags: ['에세이', '개인 블로그', '연재'] },
  { icon: '📸', label: '사진 · 영상', desc: '이미지를 보기 좋게 정리하고, 반응 수보다 작업 맥락을 함께 남기기 좋은 환경이 있습니다.', tags: ['Pixelfed', 'PeerTube', '포트폴리오'] },
  { icon: '🎵', label: '음악 · 사운드', desc: '만든 곡, 발견한 곡, 플레이리스트를 중심으로 천천히 연결됩니다. 추천 엔진보다 사람 큐레이션이 앞섭니다.', tags: ['자작곡', '플레이리스트', '소규모 씬'] },
];
---

<section id="niches">
  <div class="section-inner">
    <div class="section-meta">
      <span class="section-num">01</span>
      <div class="section-rule"></div>
      <span class="section-tag">Communities by taste</span>
    </div>

    <h2 class="section-title reveal">먼저, 어떤 사람들이 모여 있는지 보세요.</h2>
    <p class="section-copy reveal">
      연합우주를 이해하는 가장 쉬운 방법은 기술 설명보다 분위기를 먼저 보는 것입니다.
      여기서는 “다들 뭘 좋아하나요?”가 “여기는 어떤 앱인가요?”보다 더 좋은 질문입니다.
    </p>

    <div class="niches-grid stagger">
      {niches.map((niche) => (
        <article class="niche-card">
          <div class="niche-top">
            <span class="niche-icon" aria-hidden="true">{niche.icon}</span>
            <h3>{niche.label}</h3>
          </div>
          <p>{niche.desc}</p>
          <div class="niche-tags">
            {niche.tags.map((tag) => (
              <span>{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .niches-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.2rem;
  }

  .niche-card {
    min-height: 250px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    background: rgba(255, 251, 245, 0.78);
    border: 1px solid rgba(88, 69, 45, 0.12);
    box-shadow: 0 12px 30px rgba(74, 49, 18, 0.06);
  }

  .niche-top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .niche-icon {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, rgba(216, 226, 216, 0.78), rgba(255, 248, 238, 0.9));
    font-size: 1.3rem;
  }

  .niche-card h3 {
    font-size: 1.12rem;
    line-height: 1.35;
  }

  .niche-card p {
    color: var(--text-soft);
    line-height: 1.8;
    font-size: 0.95rem;
    flex: 1;
  }

  .niche-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.3rem;
  }

  .niche-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0.35rem 0.8rem;
    border-radius: var(--radius-md);
    background: rgba(255, 251, 245, 0.92);
    border: 1px solid rgba(88, 69, 45, 0.12);
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  @media (max-width: 1000px) {
    .niches-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .niches-grid {
      grid-template-columns: 1fr;
      margin-top: 1.6rem;
    }

    .niche-card {
      min-height: auto;
      padding: 1.2rem;
    }
  }
</style>
