---
import instances from '../data/instances.json';
---

<section id="instances">
  <div class="section-inner-wide">
    <div class="section-meta section-meta-padded">
      <span class="section-num">004</span>
      <div class="section-rule"></div>
      <span class="section-tag">COMMUNITIES</span>
    </div>
    <div class="instances-header">
      <h2 class="instances-heading reveal">지금 바로 시작할 수 있습니다</h2>
      <a href="#" class="instances-more">전체 인스턴스 보기 →</a>
    </div>
    <div class="instances-scroll-wrapper">
      <div class="instances-scroll">
        {instances.map((instance) => (
          <a href={instance.url} target="_blank" rel="noopener noreferrer" class="instance-card">
            <span class="instance-type-badge">{instance.type}</span>
            <span class="instance-name">{instance.name}</span>
            <div class="instance-catch">{instance.catchphrase}</div>
            <p class="instance-desc">{instance.description}</p>
            <span class="instance-join">둘러보기 →</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .instances-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding: 0 2.5rem;
  }

  .instances-heading {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .instances-more {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.06em;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s;
    flex-shrink: 0;
  }

  .instances-more:hover {
    color: var(--violet);
    border-color: var(--violet);
  }

  .instances-scroll-wrapper {
    position: relative;
  }

  .instances-scroll-wrapper::before,
  .instances-scroll-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .instances-scroll-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--bg), transparent);
  }

  .instances-scroll-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--bg), transparent);
  }

  .instances-scroll {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    padding: 0.5rem 2.5rem 2rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .instances-scroll::-webkit-scrollbar {
    display: none;
  }

  .instance-card {
    flex: 0 0 340px;
    background: var(--surface);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.4s;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    scroll-snap-align: start;
  }

  .instance-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .instance-card:nth-child(1)::before { background: linear-gradient(90deg, var(--violet), var(--indigo)); }
  .instance-card:nth-child(2)::before { background: linear-gradient(90deg, var(--pink), var(--violet)); }
  .instance-card:nth-child(3)::before { background: linear-gradient(90deg, var(--indigo), var(--cyan)); }

  .instance-card:hover::before { opacity: 1; }

  .instance-card:hover {
    background: var(--surface-2);
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .instance-type-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-bottom: 1.2rem;
  }

  .instance-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.05rem;
    font-weight: 500;
    margin-bottom: 0.6rem;
    transition: color 0.3s;
  }

  .instance-card:nth-child(1) .instance-name { color: var(--violet); }
  .instance-card:nth-child(2) .instance-name { color: var(--pink); }
  .instance-card:nth-child(3) .instance-name { color: var(--indigo); }

  .instance-catch {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
    line-height: 1.4;
  }

  .instance-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.75;
    font-weight: 300;
    flex: 1;
  }

  .instance-join {
    margin-top: 1.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-dim);
    transition: color 0.3s;
    letter-spacing: 0.05em;
  }

  .instance-card:hover .instance-join {
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .instances-header { padding: 0 1.5rem; }
    .instances-scroll { padding: 0.5rem 1.5rem 2rem; gap: 1rem; }
    .instance-card { flex: 0 0 300px; }
  }

  @media (max-width: 480px) {
    .instances-header { padding: 0 1.2rem; flex-direction: column; gap: 1rem; }
    .instances-heading { font-size: 1.8rem; }
    .instances-scroll { padding: 0.5rem 1.2rem 1.5rem; gap: 0.8rem; }
    .instances-scroll-wrapper::before,
    .instances-scroll-wrapper::after { width: 40px; }
    .instance-card { flex: 0 0 280px; padding: 1.5rem; }
    .instance-name { font-size: 0.92rem; }
    .instance-catch { font-size: 0.9rem; }
    .instance-desc { font-size: 0.8rem; }
  }
</style>
