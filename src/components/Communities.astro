---
import instances from '../data/instances.json';
---

<section id="instances">
  <div class="section-inner-wide">
    <div class="section-meta section-meta-padded">
      <span class="section-num">05</span>
      <div class="section-rule"></div>
      <span class="section-tag">Pick a first home</span>
    </div>

    <div class="instances-heading-row">
      <div>
        <h2 class="section-title reveal">
          지금 들어가 볼 수 있는<br />
          시작점.
        </h2>
        <p class="section-copy reveal">
          완벽하게 맞는 곳을 처음부터 찾지 않아도 됩니다.
          아래처럼 성격이 분명한 커뮤니티 하나를 고른 다음, 필요하면 천천히 넓혀가면 됩니다.
        </p>
      </div>

      <a href="https://fedidev.kr" target="_blank" rel="noopener noreferrer" class="btn-inline instances-link">
        더 많은 한국어 커뮤니티 보기
      </a>
    </div>

    <div class="instances-grid stagger">
      {instances.map((instance) => (
        <a href={instance.url} target="_blank" rel="noopener noreferrer" class="instance-card">
          <span class="instance-type">{instance.type}</span>
          <h3>{instance.name}</h3>
          <p class="instance-catch">{instance.catchphrase}</p>
          <p class="instance-desc">{instance.description}</p>
          <span class="instance-link">둘러보기</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .instances-heading-row {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .instances-link {
    flex-shrink: 0;
    color: var(--terracotta);
  }

  .instances-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
    width: 100%;
  }

  .instance-card {
    min-height: 320px;
    width: 100%;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 251, 245, 0.84), rgba(247, 239, 223, 0.92));
    border: 1px solid rgba(88, 69, 45, 0.12);
    box-shadow: 0 16px 30px rgba(74, 49, 18, 0.06);
  }

  .instance-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 34px rgba(74, 49, 18, 0.1);
  }

  .instance-type {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .instance-card h3 {
    margin-top: 1rem;
    font-size: 1.34rem;
    line-height: 1.2;
  }

  .instance-catch {
    margin-top: 0.8rem;
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.55;
  }

  .instance-desc {
    margin-top: 0.9rem;
    color: var(--text-soft);
    line-height: 1.8;
    font-size: 0.94rem;
    flex: 1;
  }

  .instance-link {
    margin-top: 1.3rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(88, 69, 45, 0.12);
    color: var(--sage);
    font-weight: 700;
  }

  @media (max-width: 1000px) {
    .instances-heading-row,
    .instances-grid {
      grid-template-columns: 1fr;
    }

    .instances-heading-row {
      display: grid;
      align-items: start;
    }

    .instances-link {
      justify-self: start;
    }
  }

  @media (max-width: 900px) {
    .instances-grid {
      grid-template-columns: 1fr;
      justify-items: stretch;
    }

    .instance-card {
      min-height: auto;
    }
  }
</style>
