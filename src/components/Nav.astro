<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(3, 6, 16, 0.85);
    backdrop-filter: blur(20px) saturate(1.2);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--blue);
  }

  .logo-dot {
    color: var(--pink);
  }

  ul {
    list-style: none;
    display: flex;
    gap: 2.5rem;
  }

  a {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.6rem;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.3s;
  }

  a:hover {
    color: var(--text);
  }

  .nav-cta {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    background: transparent;
    color: var(--blue);
    border: 1px solid var(--blue);
    padding: 0.5rem 1.4rem;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.3s;
    letter-spacing: 0.1em;
    box-shadow: 0 0 16px rgba(50, 140, 255, 0.2);
  }

  .nav-cta:hover {
    background: var(--blue);
    color: var(--bg);
    box-shadow: 0 0 24px rgba(50, 140, 255, 0.4);
  }

  @media (max-width: 768px) {
    nav { padding: 0.8rem 1.5rem; }
    ul { display: none; }
    .nav-cta { font-size: 0.55rem; padding: 0.45rem 1rem; }
  }

  @media (max-width: 480px) {
    nav { padding: 0.75rem 1rem; }
    .logo { font-size: 0.55rem; }
    .nav-cta { font-size: 0.5rem; padding: 0.4rem 0.8rem; }
  }
</style>
