<nav class="site-nav" aria-label="상단 배너">
  <a href="#top" class="brand" aria-label="joinfediverse.kr 홈">
    <span class="brand-copy">연합우주에 함께 하세요</span>
    <span class="brand-url">joinfediverse.kr</span>
  </a>

  <a
    href="https://github.com/fedidevkr/join-fediverse"
    target="_blank"
    rel="noopener noreferrer"
    class="nav-cta"
  >
    GitHub
  </a>
</nav>

<style>
  .site-nav {
    width: min(var(--section-width), calc(100vw - 2.5rem));
    margin: 0.35rem auto 0;
    padding: 0.7rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: rgba(255, 251, 244, 0.72);
    border: 1px solid rgba(88, 69, 45, 0.12);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    text-decoration: none;
    min-width: 0;
    gap: 0.35rem;
  }

  .brand-copy {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: 0.03em;
  }

  .brand-url {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    line-height: 1.1;
    color: var(--text-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .nav-cta {
    min-height: 44px;
    padding: 0.7rem 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--text-soft);
    border-radius: var(--radius-md);
    border: 1px solid rgba(88, 69, 45, 0.14);
    background: rgba(255, 255, 255, 0.45);
    flex-shrink: 0;
  }

  .nav-cta:hover {
    color: var(--sage);
  }

  @media (max-width: 900px) {
    .site-nav {
      width: min(var(--section-width), calc(100vw - 2rem));
      padding: 0.7rem 0.9rem;
    }
  }

  @media (max-width: 640px) {
    .site-nav {
      width: min(var(--section-width), calc(100vw - 1.25rem));
      margin-top: 0.2rem;
      padding: 0.65rem 0.8rem;
      gap: 0.75rem;
    }

    .brand-copy {
      font-size: 0.98rem;
    }

    .brand-url {
      font-size: 0.6rem;
    }

    .nav-cta {
      min-height: 40px;
      padding: 0.6rem 0.85rem;
    }
  }
</style>
