---

<nav class="top" aria-label="상단 내비게이션">
  <div class="wrap">
    <a href="/" class="brand" aria-label="홈으로"><span class="logo" aria-hidden="true"></span>연합우주</a>
    <div class="nav-links">
      <a href="/">홈</a>
      <a href="/communities">커뮤니티</a>
      <a href="/faq">FAQ</a>
      <a href="/contribute">기여하기</a>
    </div>
    <a href="/communities" class="nav-cta">시작하기 →</a>
  </div>
</nav>

<style>
  nav.top {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  nav.top .wrap {
    height: 64px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .brand:hover {
    opacity: 0.75;
  }
  .brand .logo {
    width: 28px;
    height: 28px;
    border-radius: 9px;
    background:
      radial-gradient(circle at 30% 30%, var(--mint) 0 42%, transparent 43%),
      radial-gradient(circle at 72% 68%, var(--lilac) 0 30%, transparent 31%),
      var(--ink);
    position: relative;
    transition: transform 0.2s;
  }
  .brand:hover .logo {
    transform: rotate(-6deg) scale(1.05);
  }
  .nav-links {
    display: flex;
    gap: 28px;
    justify-content: center;
    font-size: 14px;
    color: var(--ink-2);
  }
  .nav-links a {
    padding: 6px 0;
    position: relative;
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 38px;
    padding: 0 16px;
    border-radius: var(--radius-pill);
    background: var(--ink);
    color: var(--bg);
    font-size: 13.5px;
    font-weight: 500;
    transition:
      background 0.2s,
      transform 0.15s;
  }
  .nav-cta:hover {
    background: var(--mint-deep);
    transform: translateY(-1px);
  }
  @media (max-width: 720px) {
    nav.top .wrap {
      grid-template-columns: 1fr auto;
      height: 58px;
    }
    .nav-links {
      display: none;
    }
    .brand {
      font-size: 16px;
    }
    .brand .logo {
      width: 26px;
      height: 26px;
    }
  }
</style>
