---

<nav>
  <div class="logo">join<span class="logo-dot">.</span>fediverse<span class="logo-dot">.</span>kr</div>
  <ul>
    <li><a href="#niches">취향</a></li>
    <li><a href="#concept">작동원리</a></li>
    <li><a href="#instances">커뮤니티</a></li>
  </ul>
  <button class="nav-cta">시작하기 →</button>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2.5rem;
    background: rgba(6, 6, 10, 0.8);
    backdrop-filter: blur(20px) saturate(1.2);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .logo-dot {
    color: var(--violet);
  }

  ul {
    list-style: none;
    display: flex;
    gap: 2.5rem;
  }

  a {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s;
  }

  a:hover {
    color: var(--text);
  }

  .nav-cta {
    font-size: 0.78rem;
    font-weight: 500;
    background: var(--indigo);
    color: white;
    border: none;
    padding: 0.55rem 1.4rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
  }

  .nav-cta:hover {
    box-shadow: 0 0 30px rgba(99, 102, 241, 0.5);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    nav { padding: 0.8rem 1.5rem; }
    ul { display: none; }
    .nav-cta { font-size: 0.72rem; padding: 0.5rem 1.1rem; }
  }

  @media (max-width: 480px) {
    nav { padding: 0.75rem 1rem; }
    .logo { font-size: 0.72rem; }
    .nav-cta { font-size: 0.65rem; padding: 0.45rem 0.9rem; }
  }
</style>
