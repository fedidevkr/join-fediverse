---
interface Props {
  title?: string;
  body?: string;
  primary?: { href: string; label: string };
  secondary?: { href: string; label: string };
}

const {
  title = '작은 인터넷에서<br />시작해볼까요?',
  body = '이야기가 흐르는 작은 공간들이 기다리고 있어요. 마음에 드는 곳 하나를 골라 5분 안에 시작할 수 있어요.',
  primary = { href: '/communities', label: '커뮤니티 고르러 가기' },
  secondary = { href: '/faq', label: '더 궁금한 것이 있어요' },
} = Astro.props;
---

<section class="final-wrap">
  <div class="wrap">
    <div class="final">
      <div class="inner">
        <h2 set:html={title}></h2>
        <p>{body}</p>
        <div class="cta-row final-cta">
          <a href={primary.href} class="btn btn-primary">
            {primary.label} <span class="arr">→</span>
          </a>
          {secondary && <a href={secondary.href} class="btn btn-ghost white">{secondary.label}</a>}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .final-wrap {
    padding-top: 0;
  }
  .final {
    background: var(--mint);
    border-radius: 28px;
    padding: 72px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .final::before {
    content: '';
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: var(--lilac);
    filter: blur(60px);
    opacity: 0.5;
    top: -100px;
    right: -60px;
  }
  .final::after {
    content: '';
    position: absolute;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: var(--sun);
    filter: blur(60px);
    opacity: 0.4;
    bottom: -100px;
    left: -40px;
  }
  .final .inner {
    position: relative;
    z-index: 1;
  }
  .final h2 {
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin: 0 0 20px;
    color: var(--ink);
  }
  .final p {
    font-size: 17px;
    color: var(--ink-2);
    max-width: 50ch;
    margin: 0 auto 32px;
  }
  .final-cta {
    justify-content: center;
  }
  :global(.btn-ghost.white) {
    background: white;
  }
  @media (max-width: 720px) {
    .final {
      padding: 56px 24px;
      border-radius: 20px;
    }
  }
</style>
