---
import platforms from '../data/platforms.json';
---

<section id="platforms">
  <div class="section-inner">
    <div class="section-meta">
      <span class="section-num">003</span>
      <div class="section-rule"></div>
      <span class="section-tag">ALTERNATIVES</span>
    </div>
    <h2 class="platforms-heading reveal">지금 쓰는 것들, 여기에도 있습니다</h2>
    <p class="platforms-sub reveal">
      익숙한 서비스마다 연합우주의 대안이 준비되어 있습니다.
    </p>
    <div class="platforms-grid">
      {platforms.map((pair, i) => (
        <div class="platform-row" style={`--delay: ${i * 0.1}s`}>
          <div class="platform-card mainstream">
            <div class="platform-logo" style={`--logo-color: ${pair.mainstream.color}`}>
              <span class="platform-initial">{pair.mainstream.initial}</span>
            </div>
            <span class="platform-name">{pair.mainstream.name}</span>
          </div>
          <div class="platform-arrow">
            <div class="arrow-line"></div>
            <div class="arrow-pulse"></div>
            <svg class="arrow-head" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 2L10 6L2 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="platform-card fediverse">
            <div class="platform-logo" style={`--logo-color: ${pair.fediverse.color}`}>
              <span class="platform-initial">{pair.fediverse.initial}</span>
            </div>
            <span class="platform-name">{pair.fediverse.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .platforms-heading {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .platforms-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.8;
    margin-bottom: 3.5rem;
    max-width: 500px;
  }

  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .platform-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    transition: all 0.4s;
    position: relative;
    overflow: hidden;
  }

  .platform-row::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    opacity: 0;
    transition: opacity 0.4s;
    background: radial-gradient(ellipse at 70% 50%, var(--glow-indigo), transparent 70%);
    pointer-events: none;
  }

  .platform-row:hover::before { opacity: 1; }
  .platform-row:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .platform-card {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .platform-logo {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s;
  }

  .platform-row:hover .fediverse .platform-logo {
    box-shadow: 0 0 20px color-mix(in srgb, var(--logo-color) 30%, transparent);
    border-color: color-mix(in srgb, var(--logo-color) 40%, transparent);
  }

  .platform-initial {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.3s;
  }

  .fediverse .platform-initial {
    color: var(--logo-color, var(--violet));
  }

  .platform-name {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
  }

  .mainstream .platform-name {
    color: var(--text-secondary);
  }

  .fediverse .platform-name {
    color: var(--text);
  }

  /* Arrow */
  .platform-arrow {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
    width: 48px;
    position: relative;
    z-index: 1;
  }

  .arrow-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--text-dim), var(--violet));
    position: relative;
  }

  .arrow-pulse {
    position: absolute;
    top: 50%;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--violet);
    transform: translateY(-50%);
    opacity: 0;
    animation: arrowPulse 2s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  .arrow-head {
    color: var(--violet);
    flex-shrink: 0;
  }

  @keyframes arrowPulse {
    0% { left: 0; opacity: 0; }
    20% { opacity: 0.8; }
    80% { opacity: 0.8; }
    100% { left: calc(100% - 8px); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow-pulse { animation: none; opacity: 0; }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .platforms-grid { grid-template-columns: 1fr; }
    .platform-row { padding: 1.2rem 1.5rem; }
  }

  @media (max-width: 480px) {
    .platforms-heading { font-size: 1.8rem; }
    .platforms-sub { font-size: 0.9rem; margin-bottom: 2.5rem; }
    .platform-row { padding: 1rem 1.2rem; gap: 0.6rem; }
    .platform-logo { width: 36px; height: 36px; border-radius: 10px; }
    .platform-initial { font-size: 0.65rem; }
    .platform-name { font-size: 0.82rem; }
    .platform-arrow { width: 32px; }
  }
</style>
