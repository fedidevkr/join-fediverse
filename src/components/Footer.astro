---
---

<footer>
  <div class="footer-logo">join.fediverse.kr</div>
  <ul class="footer-links">
    <li><a href="https://github.com/fedidevkr/join-fediverse">GitHub</a></li>
    <li><a href="https://github.com/fedidevkr/join-fediverse/blob/main/CONTRIBUTING.md">기여하기</a></li>
    <li><a href="https://github.com/fedidevkr/join-fediverse/blob/main/LICENSE">라이선스</a></li>
  </ul>
  <span class="footer-license">CC0 — 누구나 자유롭게</span>
</footer>

<style>
  footer {
    padding: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border);
  }

  .footer-logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }

  .footer-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .footer-links a {
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer-links a:hover {
    color: var(--text-secondary);
  }

  .footer-license {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-dim);
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    footer { padding: 2rem 1.5rem; flex-wrap: wrap; gap: 1rem; }
    .footer-license { width: 100%; text-align: center; }
  }

  @media (max-width: 480px) {
    footer {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding: 2rem 1.2rem;
      text-align: center;
    }
    .footer-links { gap: 1.5rem; }
  }
</style>
